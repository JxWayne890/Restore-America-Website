# Core app
PORT=3000
JWT_SECRET=replace-with-long-random-string
DATABASE_URL=mysql://user:password@localhost:3306/restore_america_roof

# OAuth (required for login flow)
OAUTH_SERVER_URL=https://your-oauth-server.example.com
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
VITE_APP_ID=your_app_id
OWNER_OPEN_ID=owner_open_id

# Forge APIs
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://your-forge-api.example.com
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key

# Optional analytics (leave blank to disable)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
